{
  "expo": {
    "name": "indarra",
    "slug": "indarra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/gymlogo.png",
    "scheme": "indarra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/gymlogo.png",
        "backgroundImage": "./assets/images/gymlogo.png",
        "monochromeImage": "./assets/images/gymlogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.indarra"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/gymlogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/gymlogo.png",
          "imageWidth": 100,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "image": "./assets/images/gymlogo.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
